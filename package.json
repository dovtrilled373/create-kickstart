{
  "name": "create-kickstart",
  "version": "1.0.0",
  "description": "Scaffold production-ready fullstack, backend, mobile projects. React + FastAPI/Express/Go/Spring Boot. Docker, CI/CD, Terraform, Grafana, auth, CRUD, AI context (CLAUDE.md, .cursorrules). One command.",
  "type": "module",
  "bin": {
    "create-kickstart": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
