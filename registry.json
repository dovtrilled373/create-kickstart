{
  "version": "1.0.0",
  "frontend": {
    "nextjs": {
      "name": "Next.js",
      "scaffoldCmd": "npx create-next-app@latest {{name}} --ts --app --use-npm --no-import-alias --eslint --no-tailwind --no-src-dir",
      "scaffoldType": "cli",
      "port": 3000,
      "lang": "typescript",
      "devCmd": "npm run dev",
      "buildCmd": "npm run build",
      "testCmd": "npm test",
      "lintConfig": "eslint-prettier"
    },
    "react-vite": {
      "name": "React + Vite",
      "scaffoldCmd": "npm create vite@latest {{name}} -- --template react-ts",
      "scaffoldType": "cli",
      "port": 5173,
      "lang": "typescript",
      "devCmd": "npm run dev",
      "buildCmd": "npm run build",
      "testCmd": "npx vitest run",
      "lintConfig": "eslint-prettier"
    },
    "vue": {
      "name": "Vue 3 + Vite",
      "scaffoldCmd": "npm create vue@latest {{name}} -- --ts --router --pinia",
      "scaffoldType": "cli",
      "port": 5173,
      "lang": "typescript",
      "devCmd": "npm run dev",
      "buildCmd": "npm run build",
      "testCmd": "npm test",
      "lintConfig": "eslint-prettier"
    },
    "svelte": {
      "name": "SvelteKit",
      "scaffoldCmd": "npx sv create {{name}} --template minimal --types ts",
      "scaffoldType": "cli",
      "port": 5173,
      "lang": "typescript",
      "devCmd": "npm run dev",
      "buildCmd": "npm run build",
      "testCmd": "npm test",
      "lintConfig": "eslint-prettier"
    },
    "angular": {
      "name": "Angular",
      "scaffoldCmd": "npx @angular/cli@latest new {{name}} --skip-git --style css --ssr false",
      "scaffoldType": "cli",
      "port": 4200,
      "lang": "typescript",
      "devCmd": "npx ng serve",
      "buildCmd": "npx ng build",
      "testCmd": "npx ng test --watch=false",
      "lintConfig": "eslint-prettier"
    }
  },
  "backend": {
    "fastapi": {
      "name": "FastAPI",
      "scaffoldType": "template",
      "port": 8000,
      "lang": "python",
      "devCmd": "uvicorn app.main:app --reload --port 8000",
      "buildCmd": "echo 'No build step required'",
      "testCmd": "pytest -v",
      "lintConfig": "ruff"
    },
    "express": {
      "name": "Express",
      "scaffoldType": "template",
      "port": 3001,
      "lang": "typescript",
      "devCmd": "npx tsx watch src/index.ts",
      "buildCmd": "npx tsc",
      "testCmd": "npx vitest run",
      "lintConfig": "eslint-prettier"
    },
    "hono": {
      "name": "Hono",
      "scaffoldCmd": "npm create hono@latest {{name}}",
      "scaffoldType": "cli",
      "port": 3001,
      "lang": "typescript",
      "devCmd": "npm run dev",
      "buildCmd": "npm run build",
      "testCmd": "npx vitest run",
      "lintConfig": "eslint-prettier"
    },
    "django": {
      "name": "Django",
      "scaffoldType": "template",
      "port": 8000,
      "lang": "python",
      "devCmd": "python manage.py runserver 0.0.0.0:8000",
      "buildCmd": "python manage.py collectstatic --noinput",
      "testCmd": "python manage.py test",
      "lintConfig": "ruff"
    },
    "go-chi": {
      "name": "Go (Chi)",
      "scaffoldType": "template",
      "port": 8080,
      "lang": "go",
      "devCmd": "go run ./cmd/server",
      "buildCmd": "go build -o bin/server ./cmd/server",
      "testCmd": "go test ./...",
      "lintConfig": "golangci-lint"
    },
    "spring-boot": {
      "name": "Spring Boot",
      "scaffoldType": "template",
      "port": 8080,
      "lang": "java",
      "devCmd": "./mvnw spring-boot:run",
      "buildCmd": "./mvnw package -DskipTests",
      "testCmd": "./mvnw test",
      "lintConfig": "checkstyle"
    },
    "axum": {
      "name": "Axum",
      "scaffoldType": "template",
      "port": 8080,
      "lang": "rust",
      "devCmd": "cargo watch -x run",
      "buildCmd": "cargo build --release",
      "testCmd": "cargo test",
      "lintConfig": "clippy"
    },
    "aspnet": {
      "name": "ASP.NET",
      "scaffoldType": "cli",
      "scaffoldCmd": "dotnet new webapi --name {{name}} --no-https -o {{name}}",
      "port": 5000,
      "lang": "csharp",
      "devCmd": "dotnet watch run",
      "buildCmd": "dotnet publish -c Release",
      "testCmd": "dotnet test",
      "lintConfig": "dotnet-format"
    },
    "phoenix": {
      "name": "Phoenix",
      "scaffoldType": "cli",
      "scaffoldCmd": "mix phx.new {{name}} --no-html --no-assets --no-mailer --no-dashboard",
      "port": 4000,
      "lang": "elixir",
      "devCmd": "mix phx.server",
      "buildCmd": "MIX_ENV=prod mix release",
      "testCmd": "mix test",
      "lintConfig": "mix-format"
    }
  },
  "mobile": {
    "react-native": {
      "name": "React Native",
      "scaffoldCmd": "npx react-native init {{name}} --template react-native-template-typescript",
      "scaffoldType": "cli",
      "port": 8081,
      "lang": "typescript",
      "devCmd": "npx react-native start",
      "buildCmd": "npx react-native build-android",
      "testCmd": "npm test",
      "lintConfig": "eslint-prettier"
    },
    "flutter": {
      "name": "Flutter",
      "scaffoldCmd": "flutter create {{name}}",
      "scaffoldType": "cli",
      "port": 0,
      "lang": "dart",
      "devCmd": "flutter run",
      "buildCmd": "flutter build apk",
      "testCmd": "flutter test",
      "lintConfig": "flutter-analyze"
    },
    "swift": {
      "name": "Swift (iOS)",
      "scaffoldType": "template",
      "port": 0,
      "lang": "swift",
      "devCmd": "open *.xcodeproj",
      "buildCmd": "xcodebuild -scheme {{name}}",
      "testCmd": "xcodebuild test -scheme {{name}}",
      "lintConfig": "swiftlint"
    },
    "kotlin": {
      "name": "Kotlin (Android)",
      "scaffoldType": "template",
      "port": 0,
      "lang": "kotlin",
      "devCmd": "./gradlew installDebug",
      "buildCmd": "./gradlew assembleRelease",
      "testCmd": "./gradlew test",
      "lintConfig": "ktlint"
    }
  },
  "standalone": {
    "python-cli": {
      "name": "Python CLI (Click)",
      "scaffoldType": "template",
      "port": 0,
      "lang": "python",
      "devCmd": "python -m {{name}}",
      "buildCmd": "pip install build && python -m build",
      "testCmd": "pytest -v",
      "lintConfig": "ruff"
    },
    "python-lib": {
      "name": "Python Library",
      "scaffoldType": "template",
      "port": 0,
      "lang": "python",
      "devCmd": "pip install -e '.[dev]'",
      "buildCmd": "pip install build && python -m build",
      "testCmd": "pytest -v",
      "lintConfig": "ruff"
    },
    "node-cli": {
      "name": "Node.js CLI",
      "scaffoldType": "template",
      "port": 0,
      "lang": "typescript",
      "devCmd": "npx tsx watch src/index.ts",
      "buildCmd": "npx tsup",
      "testCmd": "npx vitest run",
      "lintConfig": "eslint-prettier"
    }
  }
}
